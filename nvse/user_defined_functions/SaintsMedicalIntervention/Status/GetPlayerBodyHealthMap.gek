begin function {}

	array_var aMap = Ar_Construct "stringmap"

	let aMap["head"] := (Player.GetAV PerceptionCondition)
	let aMap["torso"] := (Player.GetAV EnduranceCondition)
	let aMap["leftarm"] := (Player.GetAV LeftAttackCondition)
	let aMap["rightarm"] := (Player.GetAV RightAttackCondition)
	let aMap["leftleg"] := (Player.GetAV LeftMobilityCondition)
	let aMap["rightleg"] := (Player.GetAV RightMobilityCondition)

	SetFunctionValue aMap

	let aMap := Ar_Null

end
